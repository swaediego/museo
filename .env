# =============================================================================
# Variables de entorno para docker-compose
# ESTE ARCHIVO NO DEBE COMMETEaRSE (está en .gitignore)
# Modificá los valores que necesites y guardá
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=museo_db
POSTGRES_USER=Miguel
# Cambiá esto por una contraseña real
POSTGRES_PASSWORD=museo_db
# --- MongoDB ---
MONGO_DB=galeria_catalog
MONGO_PORT=27017

# --- Backend (Spring Boot) ---
BACKEND_PORT=8080

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
# URL que el navegador usa para llegar al backend.
# En Linux Mint desktop, "localhost" funciona porque el puerto está publicado en el host.
NEXT_PUBLIC_API_URL=http://localhost:8080
